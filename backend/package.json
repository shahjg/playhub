{
  "name": "playhub-backend",
  "version": "1.0.0",
  "description": "PlayHub multiplayer game server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test-bots": "node test-bots.js",
    "test-werewolf": "node test-bots.js --game werewolf --bots 8 --host --start",
    "test-imposter": "node test-bots.js --game imposter --bots 5 --host --start",
    "test-spyfall": "node test-bots.js --game spyfall --bots 6 --host --start",
    "test-herd": "node test-bots.js --game herd-mentality --bots 5 --host --start",
    "test-trivia": "node test-bots.js --game trivia-royale --bots 10 --host --start",
    "test-party-100": "node test-bots.js --game trivia-royale --bots 99 --host --quiet",
    "test-party-50": "node test-bots.js --game trivia-royale --bots 49 --host --quiet",
    "test-party-25": "node test-bots.js --game trivia-royale --bots 24 --host"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "stripe": "^14.10.0",
    "@supabase/supabase-js": "^2.39.0",
    "socket.io-client": "^4.6.1"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}